{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -z \"$DATAGEN_API_KEY\" ]; then echo 'DataGen not configured. Run /datagen:setup to connect tools.'; fi",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/validate-agent-frontmatter.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
